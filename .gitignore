# .gitignore
# Build directories
build/
cmake-build-*/
out/
vcpkg/
vcpkg_installed/

# IDE files
.vs/
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Compiler artifacts
*.obj
*.pdb
*.lib
*.dll
*.so
*.dylib

# Third party (but keep the directory structure)
third_party/*/!.gitkeep
third_party/*/.gitignore

# Logs
*.log
*.tmp
.agents/
.claude/
.cursor/
.gemini/
temp/
tmp/



# CMake cache
CMakeCache.txt
CMakeFiles/
cmake_install.cmake

# Visual Studio
*.sln
*.vcxproj*
*.user
*.filters
ipch/


# Shaders
*.spv
*.pdb
*.ilk

# Generated headers
include/generated/shader_layouts.h
/bin/Debug
